# --- Party Queue Server (local dev) ---

# Server
PORT=4000
CORS_ORIGIN=*

# Supabase
# Find these in: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Public anon/publishable key (safe for clients)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Secret service role key (SERVER ONLY - never expose to iOS/web)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxx
